"""
Phase 4 test suite for hardening_engine/rules.py -- no live components
required, just the YAML mapping file on disk.

Run with:
    python -m pytest tests/test_hardening_engine.py -v
"""

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from hardening_engine.rules import (
    load_mappings,
    get_edge_recommendations,
    get_evidence_recommendation,
    build_recommendations,
)


def test_load_mappings_has_expected_top_level_keys():
    mappings = load_mappings()
    assert "edge_recommendations" in mappings
    assert "evidence_recommendations" in mappings


def test_get_edge_recommendations_returns_known_kind():
    recs = get_edge_recommendations(["GenericAll"])
    assert len(recs) == 1
    assert "least privilege" in recs[0]


def test_get_edge_recommendations_dedupes():
    recs = get_edge_recommendations(["GenericAll", "GenericAll", "MemberOf"])
    assert len(recs) == 2  # GenericAll counted once, plus MemberOf


def test_get_edge_recommendations_skips_unknown_kind():
    recs = get_edge_recommendations(["SomeMadeUpEdgeType"])
    assert recs == []


def test_get_edge_recommendations_preserves_order():
    recs = get_edge_recommendations(["MemberOf", "GenericAll"])
    assert "nest" in recs[0].lower() or "group" in recs[0].lower()  # MemberOf rec first


def test_get_evidence_recommendation_dcsync():
    rec = get_evidence_recommendation("active_dcsync_on_path")
    assert rec is not None
    assert "krbtgt" in rec.lower()


def test_get_evidence_recommendation_none_type_returns_none():
    assert get_evidence_recommendation(None) is None


def test_get_evidence_recommendation_unknown_type_returns_none():
    assert get_evidence_recommendation("not_a_real_evidence_type") is None


def test_build_recommendations_combines_evidence_and_edges():
    recs = build_recommendations(
        edge_kinds=["GenericAll", "MemberOf"],
        evidence_type="active_kerberoast_on_path",
    )
    # Evidence rec first, then edge recs
    assert len(recs) == 3
    assert "rc4" in recs[0].lower() or "kerberoast" in recs[0].lower()


def test_build_recommendations_with_no_evidence():
    recs = build_recommendations(edge_kinds=["GenericAll"], evidence_type=None)
    assert len(recs) == 1


if __name__ == "__main__":
    test_load_mappings_has_expected_top_level_keys()
    test_get_edge_recommendations_returns_known_kind()
    test_get_edge_recommendations_dedupes()
    test_get_edge_recommendations_skips_unknown_kind()
    test_get_edge_recommendations_preserves_order()
    test_get_evidence_recommendation_dcsync()
    test_get_evidence_recommendation_none_type_returns_none()
    test_get_evidence_recommendation_unknown_type_returns_none()
    test_build_recommendations_combines_evidence_and_edges()
    test_build_recommendations_with_no_evidence()
    print("All Phase 4 hardening engine tests passed.")
